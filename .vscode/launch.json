{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/../../crates/freight/examples/cpp/hello"
      ],
      "outFiles": [],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**",
        "!${env:HOME}/.vscode-server/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${env:HOME}/.vscode-server/**"
      ],
      "preLaunchTask": "bun: package"
    },
    {
      "name": "Attach to freight LSP (Rust)",
      "type": "lldb",
      "request": "attach",
      "program": "${workspaceFolder}/../../target/debug/freight",
      "pid": "${command:pickProcess}",
      "stopOnEntry": false,
      "sourceLanguages": ["rust"]
    }
  ]
}
