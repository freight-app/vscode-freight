{
  "name": "vscode-freight",
  "displayName": "Freight",
  "description": "VS Code support for freight.toml, Freight tasks, and freight lsp.",
  "version": "0.2.0",
  "publisher": "freight",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Build Tools",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:freight-manifest",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:cuda-cpp",
    "onLanguage:objective-c",
    "onLanguage:objective-cpp",
    "onLanguage:fortran",
    "onLanguage:FortranFreeForm",
    "onLanguage:FortranFixedForm",
    "onLanguage:asm",
    "onLanguage:nasm",
    "onLanguage:gas",
    "workspaceContains:freight.toml",
    "onDebug",
    "onDebugInitialConfigurations",
    "onDebugResolve:freight",
    "onDebugAdapterProtocolTracker:freight",
    "onCommand:freight.restartLanguageServer",
    "onCommand:freight.generateCompileCommands",
    "onCommand:freight.run",
    "onCommand:freight.debug",
    "onView:freight.explorerView"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "bun build src/extension.ts --target=node --format=cjs --sourcemap=linked --external vscode --outdir dist",
    "watch": "bun build src/extension.ts --target=node --format=cjs --sourcemap=linked --external vscode --outdir dist --watch",
    "check": "bun build src/extension.ts --target=node --format=cjs --external vscode --outdir /tmp/vscode-freight-check",
    "test": "bun build src/extension.ts --target=node --format=cjs --external vscode --outdir /tmp/vscode-freight-test && FREIGHT_EXTENSION_TEST_ENTRY=/tmp/vscode-freight-test/extension.js node tests/dap-config.test.js",
    "package": "bun run compile"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "freight-explorer",
          "title": "Freight",
          "icon": "images/freight-icon.svg"
        }
      ]
    },
    "views": {
      "freight-explorer": [
        {
          "id": "freight.explorerView",
          "name": "Freight Explorer",
          "when": "workspaceContains:freight.toml"
        }
      ]
    },
    "languages": [
      {
        "id": "freight-manifest",
        "aliases": [
          "Freight Manifest",
          "freight.toml"
        ],
        "filenames": [
          "freight.toml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "freight-manifest",
        "scopeName": "source.toml.freight",
        "path": "./syntaxes/freight.tmLanguage.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "freight",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "Freight command to run."
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Arguments passed to the Freight command."
          }
        }
      }
    ],
    "configuration": {
      "title": "Freight",
      "properties": {
        "freight.executablePath": {
          "type": "string",
          "default": "freight",
          "description": "Path to the freight executable."
        },
        "freight.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Start freight lsp for freight.toml and source-file passthrough support."
        },
        "freight.lsp.clangdPath": {
          "type": "string",
          "default": "clangd",
          "description": "Path to clangd used by freight lsp for C-family source files."
        },
        "freight.lsp.fortlsPath": {
          "type": "string",
          "default": "fortls",
          "description": "Path to fortls used by freight lsp for Fortran source files."
        },
        "freight.lsp.asmLspPath": {
          "type": "string",
          "default": "asm-lsp",
          "description": "Path to asm-lsp used by freight lsp for assembly source files."
        },
        "freight.lsp.profile": {
          "type": "string",
          "default": "dev",
          "description": "Freight profile used when freight lsp refreshes compile_commands.json."
        },
        "freight.lsp.useClangBridge": {
          "type": "boolean",
          "default": false,
          "description": "Experimental: use Freight's in-process clang bridge to serve C/C++ language features (hover, go-to-definition, completion, document symbols, folding, references, highlight, semantic tokens) instead of clangd. Off by default while the bridge matures; clangd is the reliable path."
        },
        "freight.lsp.clangdArgs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra flags passed verbatim to clangd (e.g. [\"--hover-style=detailed\"])."
        },
        "freight.lsp.enableClangd": {
          "type": "boolean",
          "default": true,
          "description": "Allow freight lsp to start clangd."
        },
        "freight.lsp.enableFortls": {
          "type": "boolean",
          "default": true,
          "description": "Allow freight lsp to start fortls."
        },
        "freight.lsp.enableAsmLsp": {
          "type": "boolean",
          "default": true,
          "description": "Allow freight lsp to start asm-lsp."
        },
        "freight.lsp.logLevel": {
          "type": "string",
          "default": "",
          "enum": ["", "error", "warn", "info", "debug", "trace"],
          "enumDescriptions": [
            "No logging (default)",
            "Errors only",
            "Errors and warnings",
            "Lifecycle events (start, shutdown, compile_commands refresh)",
            "Hover enrichment, message routing, per-hover details",
            "Raw clangd output + all of the above"
          ],
          "description": "Log level for freight lsp. Output appears in the Freight Language Server output channel. Automatically set to 'debug' when the extension runs in development mode (F5)."
        }
      }
    },
    "commands": [
      {
        "command": "freight.restartLanguageServer",
        "title": "Freight: Restart Language Server"
      },
      {
        "command": "freight.attachRustDebugger",
        "title": "Freight: Attach Rust Debugger to LSP"
      },
      {
        "command": "freight.generateCompileCommands",
        "title": "Freight: Generate compile_commands.json"
      },
      {
        "command": "freight.run",
        "title": "Freight: Run"
      },
      {
        "command": "freight.debug",
        "title": "Freight: Debug"
      },
      {
        "command": "freight.refreshExplorer",
        "title": "Freight: Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "freight.openDepDoc",
        "title": "Freight: Open Dependency Docs",
        "icon": "$(book)"
      },
      {
        "command": "freight.runTarget",
        "title": "Freight: Run",
        "icon": "$(run)"
      },
      {
        "command": "freight.debugTarget",
        "title": "Freight: Debug",
        "icon": "$(debug-alt)"
      },
      {
        "command": "freight.toggleProfile",
        "title": "Freight: Switch Profile"
      },
      {
        "command": "freight.pickTarget",
        "title": "Freight: Set Active Target",
        "icon": "$(run)"
      },
      {
        "command": "freight.pickSysroot",
        "title": "Freight: Set Sysroot",
        "icon": "$(server-environment)"
      },
      {
        "command": "freight.pickFamily",
        "title": "Freight: Set Compiler Family",
        "icon": "$(chip)"
      }
    ],
    "debuggers": [
      {
        "type": "freight",
        "label": "Freight",
        "configurationAttributes": {
          "launch": {
            "required": [
              "request",
              "name"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "run",
                  "debug"
                ],
                "default": "run",
                "description": "Run with freight run, or build debug profile and launch freight debug."
              },
              "release": {
                "type": "boolean",
                "default": false,
                "description": "Pass --release to freight run."
              },
              "profile": {
                "type": "string",
                "default": "dev",
                "description": "Freight profile used when building before debug launch."
              },
              "package": {
                "type": "string",
                "description": "Workspace package passed as -p."
              },
              "bin": {
                "type": "string",
                "description": "Binary passed as --bin for freight run, or positional binary for freight debug."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments passed to the program after --."
              },
              "features": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Features passed to freight run."
              },
              "noDefaultFeatures": {
                "type": "boolean",
                "default": false,
                "description": "Pass --no-default-features to freight run."
              },
              "buildBeforeDebug": {
                "type": "boolean",
                "default": true,
                "description": "Run freight build as a visible VS Code terminal task before launching freight dap."
              },
              "debugger": {
                "type": "string",
                "enum": [
                  "gdb",
                  "cuda-gdb",
                  "lldb"
                ],
                "description": "Optional debugger backend override. Omit to use Freight's developer config."
              },
              "debuggerPath": {
                "type": "string",
                "description": "Optional debugger command or adapter path, for example gdb, /usr/bin/gdb, or /usr/bin/lldb-dap."
              },
              "debuggerArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Extra native debugger adapter process arguments appended after config.toml debugger args."
              },
              "stopAtEntry": {
                "type": "boolean",
                "default": false,
                "description": "Stop at the beginning of the main subprogram before continuing."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Environment variables passed to the debuggee."
              },
              "sysroot": {
                "type": "string",
                "description": "Cross-compile sysroot path passed to the compiler."
              },
              "family": {
                "type": "string",
                "enum": ["gcc", "clang", "msvc", "nvcc"],
                "description": "Compiler family override. Omit to use the status bar / auto-detect."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for freight."
              }
            }
          },
          "attach": {
            "required": [
              "request",
              "name"
            ],
            "properties": {
              "debugger": {
                "type": "string",
                "enum": [
                  "gdb",
                  "cuda-gdb",
                  "lldb"
                ],
                "description": "Optional debugger backend override. Omit to use Freight's developer config."
              },
              "debuggerPath": {
                "type": "string",
                "description": "Optional debugger command or adapter path, for example gdb, /usr/bin/gdb, or /usr/bin/lldb-dap."
              },
              "debuggerArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Extra native debugger adapter process arguments appended after config.toml debugger args."
              },
              "pid": {
                "type": "number",
                "description": "Process id to attach to."
              },
              "processName": {
                "type": "string",
                "description": "Process name used by native adapters that support name-based attach."
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}",
                "description": "Working directory for freight."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Freight: Run",
            "type": "freight",
            "request": "launch",
            "mode": "run",
            "cwd": "${workspaceFolder}",
            "args": []
          },
          {
            "name": "Freight: Run Release",
            "type": "freight",
            "request": "launch",
            "mode": "run",
            "release": true,
            "cwd": "${workspaceFolder}",
            "args": []
          },
          {
            "name": "Freight: Debug",
            "type": "freight",
            "request": "launch",
            "mode": "debug",
            "cwd": "${workspaceFolder}",
            "args": []
          },
          {
            "name": "Freight: Attach",
            "type": "freight",
            "request": "attach",
            "mode": "debug",
            "cwd": "${workspaceFolder}"
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "freight.restartLanguageServer" },
        { "command": "freight.generateCompileCommands" },
        { "command": "freight.run" },
        { "command": "freight.debug" },
        { "command": "freight.refreshExplorer" },
        { "command": "freight.openDepDoc" },
        { "command": "freight.toggleProfile" },
        { "command": "freight.pickTarget" },
        { "command": "freight.pickSysroot" },
        { "command": "freight.pickFamily" }
      ],
      "view/title": [
        {
          "command": "freight.refreshExplorer",
          "when": "view == freight.explorerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "freight.openDepDoc",
          "when": "view == freight.explorerView && viewItem == freightDep",
          "group": "inline"
        },
        {
          "command": "freight.runTarget",
          "when": "view == freight.explorerView && viewItem == freightBinTarget",
          "group": "inline@1"
        },
        {
          "command": "freight.debugTarget",
          "when": "view == freight.explorerView && viewItem == freightBinTarget",
          "group": "inline@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "workbench.action.tasks.build",
        "key": "ctrl+shift+b",
        "when": "resourceFilename == freight.toml"
      }
    ],
    "problemMatchers": [
      {
        "name": "freight",
        "owner": "freight",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^(error|warning):\\s+(.*)$",
            "severity": 1,
            "message": 2
          },
          {
            "regexp": "^\\s+([^:]+):(\\d+):(\\d+)\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0"
  }
}
